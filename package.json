{
  "name": "contact-ingestion",
  "version": "1.0.0",
  "private": true,
  "description": "Production-grade multi-tenant contact ingestion API",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "migrate": "node dist/migrate.js",
    "migrate:dev": "tsx src/migrate.ts"
  },
  "dependencies": {
    "fastify": "^5.2.1",
    "libphonenumber-js": "^1.11.18",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "prom-client": "^15.1.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.8"
  }
}
